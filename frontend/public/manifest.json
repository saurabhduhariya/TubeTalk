{
  "manifest_version": 3,
  "name": "YouTube LCEL Chatbot",
  "version": "1.0",
  "description": "Chat with YouTube videos using LangChain and Pinecone.",
  "permissions": [
    "activeTab",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:8000/*"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open YT Chat"
  },
  "background": {
    "service_worker": "background.js"
  }
}